					<response> Response 3 </response>
				</match>
				<match>
					<premise> Premise Distractor 1 </premise>
					<premise> Premise Distractor 2 </premise>
				</match>
				<match>
					<response> Response Distractor 1 </response>
				</match>
			</cardsort>
		</exercise>

	</section>

	<section xml:id="sec-implicit-diff">
		<title>Implicit Differentiation</title>

		<exercise label="hparson-derivative" language="math">
			<title> Unscramble the Derivative </title>
			<statement>
			<p>
				Rearrange the blocks to form a valid derivative statement.
			</p>
			</statement>
			<blocks layout="horizontal" randomize="yes">
				<block order="1"><m>\left(\right.</m></block>
				<block order="2"><m>x^2</m></block>
				<block order="3"><m>\sin x</m></block>
				<block order="4"><m>\left.\right)'</m></block>
				<block order="1"><m>=</m></block>
				<block order="1"><m>2x</m></block>
				<block order="3"><m>\sin x</m></block>
				<block order="4"><m>+</m></block>
				<block order="1"><m>x^2</m></block>
				<block order="1"><m>\cos x</m></block>
			</blocks>
		</exercise>

		<exercise xml:id="parson-steps1" label="ex-parson-steps">
		<title> List the Steps </title>
		<idx>order steps</idx>
		<statement>
			<p>
				Suppose <m>y</m> is a function of <m>x</m>, and we want to find <m>\frac{dy}{dx}</m> given the equation:
				<me>y - y^2 = 3x</me>.
				List the implicit differentiation steps in the correct order in the right column.
			</p>
		</statement>
		<blocks>
			<block>
				<m>\frac{d}{dx}(y - y^2) = \frac{d}{dx}(3x)</m>
			</block>
			<block>
				<m>\frac{d}{dx}(y) - \frac{d}{dx}(y^2) = \frac{d}{dx}(3x)</m>
			</block>
			<block>
				<m>\frac{dy}{dx} - 2y\frac{dy}{dx} = 3</m>
			</block>
			<block>
				<m>\frac{dy}{dx}\left(1-2y\right) = 3</m>
			</block>
			<block>
				<m>\frac{dy}{dx} = \frac{3}{1-2y}</m>
			</block>
		</blocks>
		</exercise>

		<exercise xml:id="reason-steps2" label="ex-matching-step-reason">
			<title> Product Rule Match </title>

			<statement>
				<p>
					The product rule is given by the formula
					<me>\frac{d}{dx}(f\cdot g) = f\frac{dg}{dx} + g\frac{df}{dx}</me>.
					Match two functions on the left with the product rule they would produce on the right.
				</p>
			</statement>
			<cardsort>
				<match>
					<premise><me>x^2</me></premise>
					<premise><me>\tan x</me></premise>
					<response><me>2x\tan x + x^2 \sec^2 x</me></response>
				</match>
				<match>
					<premise><me>\ln x</me></premise>
					<premise><me>\sin x</me></premise>
					<response><me>\frac{\sin x}{x} + \cos x \ln x</me></response>
				</match>
				<match>
					<premise><me>\sin x</me></premise>
					<premise><me>\csc x</me></premise>
					<response><me>-\cos x \csc x + \sin x \csc x \cot x</me></response>
				</match>
				<match>
					<premise><me>\sfrac{1}{x}</me></premise>
					<premise><me>2x</me></premise>
					<premise><me>\cos x</me></premise>
				</match>
			</cardsort>
		</exercise>

		<exercise xml:id="reason-steps4" label="ex-matching-step-reason1">
		<title> Match the Reason to the Step </title>
		<idx>matching steps to order</idx>
		<statement>
			<p>
				Suppose we want apply implicit differentiation to find <m>\frac{dy}{dx}</m> for the equation
				<me>y + y^2 = 3x^6</me>.
				Match the one or more tasks on the right that was applied in each step on the left.
			</p>
		</statement>
		<cardsort>
			<match>
				<premise>apply the derivative with respect <m>x</m> to both sides</premise>
				<response><me>\frac{d}{dx}(y + y^2) = \frac{d}{dx}(3x^6)</me></response>
			</match>
			<match>
				<premise>sum rule</premise>
				<response><me>\frac{d}{dx}(y) + \frac{d}{dx}(y^2) = \frac{d}{dx}(3x^6)</me></response>
			</match>
			<match>
				<premise>chain rule</premise>
				<premise>power rule</premise>
				<response><me>\frac{dy}{dx} + 2y\frac{dy}{dx} = 18x^5</me></response>
			</match>
			<match>
				<premise>factor</premise>
				<response><me>\frac{dy}{dx}\left(1+2y\right) = 18x^5</me></response>
			</match>
			<match>
				<premise>divide both sides by <m>1+2y</m></premise>
				<response><me>\frac{dy}{dx} = \frac{18x^5}{1+2y}</me></response>
			</match>
			<match>
				<premise>quotient rule</premise>
				<premise>simplify</premise>
			</match>
		</cardsort>
		</exercise>

		<exercise>
			<statement>
				<p>
					State or describe what the word <q>implicit</q> refers to in <q>implicit differentiation</q>. 
				</p>
			</statement>
			<response />
		</exercise>

		<exercise>
			<statement>
				<p>
					Suppose you are given the derivative, <m>f'(x)</m>, but not the function <m>f(x)</m> itself. Describe the type of information you can obtain about <m>f(x)</m>.   
				</p>
			</statement>
			<response />
		</exercise>

	</section>

</chapter>